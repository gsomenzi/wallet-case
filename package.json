{
    "name": "wallet-case",
    "private": true,
    "version": "1.0.0",
    "description": "",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:bff\" \"npm run dev:mobile\"",
        "dev:bff": "npm run dev -w @wallet/bff",
        "dev:mobile": "npm run start -w @wallet/mobile",
        "dev:mobile:android": "npm run start -w @wallet/mobile -- --android",
        "dev:mobile:ios": "npm run start -w @wallet/mobile -- --ios",
        "test:bff": "npm run test -w @wallet/bff",
        "test:bff:cov": "npm run test:cov -w @wallet/bff",
        "test:mobile": "npm run test -w @wallet/mobile",
        "lint": "biome check .",
        "format": "biome format . --write",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "Guilherme Somenzi <somenziguilherme@gmail.com>",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@types/jest": "^30.0.0",
        "concurrently": "^9.2.1",
        "husky": "^9.1.7"
    }
}
